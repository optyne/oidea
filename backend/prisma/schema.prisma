generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 使用者與認證
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  displayName   String
  passwordHash  String
  avatarUrl     String?
  status        String    @default("offline") // online, away, dnd, offline
  statusMessage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  accounts           Account[]
  workspaceMembers   WorkspaceMember[]
  channelMembers     ChannelMember[]
  sentMessages       Message[]            @relation("MessageSender")
  ownedWorkspaces    Workspace[]          @relation("WorkspaceOwner")
  assignedTasks      Task[]               @relation("TaskAssignee")
  taskComments       TaskComment[]
  meetingOrganizer   Meeting[]            @relation("MeetingOrganizer")
  meetingParticipant MeetingParticipant[]
  reactions          MessageReaction[]
  mentions           Mention[]
  readStatuses       MessageReadStatus[]
  typingIndicators   TypingIndicator[]
  notifications      Notification[]
  sharedFiles        File[]
  activities         TaskActivity[]
  createdDatabases   Database[]           @relation("DatabaseCreator")
  reminders          Reminder[]           @relation("ReminderCreator")
  messageSnippets    MessageSnippet[]     @relation("SnippetCreator")
  scheduledMessages  ScheduledMessage[]   @relation("ScheduledMessageCreator")
  automationRules    AutomationRule[]     @relation("AutomationRuleCreator")

  @@map("users")
}

model Account {
  id           String   @id @default(uuid())
  userId       String
  provider     String // local, google, github
  providerId   String?
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("accounts")
}

// ============================================================
// 工作空間
// ============================================================

model Workspace {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  iconUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  ownerId String @map("ownerId")
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members   WorkspaceMember[]
  channels  Channel[]
  projects  Project[]
  meetings  Meeting[]
  boards    Whiteboard[]
  databases         Database[]
  reminders         Reminder[]
  snippets          MessageSnippet[]
  scheduledMessages ScheduledMessage[]
  automationRules   AutomationRule[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member") // owner, admin, member
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ============================================================
// 頻道與訊息
// ============================================================

model Channel {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  type        String    @default("public") // public, private, dm
  description String?
  topic       String?
  icon        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members        ChannelMember[]
  messages       Message[]
  pinnedMessages PinnedMessage[]

  @@unique([workspaceId, name])
  @@map("channels")
}

model ChannelMember {
  id         String   @id @default(uuid())
  channelId  String
  userId     String
  role       String   @default("member") // admin, member
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model Message {
  id          String    @id @default(uuid())
  channelId   String
  senderId    String
  parentId    String? // for thread replies
  broadcastId String? // C-16 跨頻道廣播：同一批廣播出去的訊息共用此 id
  type        String    @default("text") // text, image, file, system
  content     String?
  metadata    Json? // extra data like file info
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  channel Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parent  Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Message[] @relation("MessageThread")

  reactions       MessageReaction[]
  readStatuses    MessageReadStatus[]
  mentions        Mention[]
  pinnedIn        PinnedMessage[]
  files           File[]
  convertedTasks  Task[]              @relation("MessageConvertedTasks")

  @@index([channelId, createdAt])
  @@index([parentId])
  @@index([broadcastId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageReadStatus {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_read_statuses")
}

model Mention {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mentions")
}

model PinnedMessage {
  id        String   @id @default(uuid())
  channelId String
  messageId String
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@map("pinned_messages")
}

model TypingIndicator {
  id        String   @id @default(uuid())
  channelId String
  userId    String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("typing_indicators")
}

// ============================================================
// 專案與任務
// ============================================================

model Project {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  icon        String?
  color       String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  columns ProjectColumn[]
  tasks   Task[]
  boards  Whiteboard[]

  @@map("projects")
}

model ProjectColumn {
  id        String  @id @default(uuid())
  projectId String
  name      String
  color     String?
  position  Int
  wipLimit  Int?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("project_columns")
}

model Task {
  id                 String    @id @default(uuid())
  projectId          String
  columnId           String
  title              String
  description        String?
  priority           String    @default("medium") // urgent, high, medium, low
  position           Int       @default(0)
  dueDate            DateTime?
  startDate          DateTime?
  completedAt        DateTime?
  sourceMessageId    String? // C-18 訊息轉任務：可回溯訊息來源
  recurrence         String    @default("none") // P-14: none | daily | weekly | monthly | yearly
  recurrenceInterval Int       @default(1)
  recurringSourceId  String? // P-14: 指向本循環序列的根任務
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column          ProjectColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee        User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId      String?
  sourceMessage   Message?      @relation("MessageConvertedTasks", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  recurringSource Task?         @relation("TaskRecurringSeries", fields: [recurringSourceId], references: [id], onDelete: SetNull)
  recurringInstances Task[]     @relation("TaskRecurringSeries")

  tags       TaskTag[]
  comments   TaskComment[]
  subtasks   Subtask[]
  activities TaskActivity[]
  files      File[]

  @@index([projectId, columnId, position])
  @@index([sourceMessageId])
  @@index([recurringSourceId])
  @@map("tasks")
}

model TaskTag {
  id     String @id @default(uuid())
  taskId String
  name   String
  color  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_tags")
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Subtask {
  id        String  @id @default(uuid())
  taskId    String
  title     String
  completed Boolean @default(false)
  position  Int     @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("subtasks")
}

model TaskActivity {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String // created, moved, updated, assigned, commented
  details   Json?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_activities")
}

// ============================================================
// 會議系統
// ============================================================

model Meeting {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  meetingUrl  String?
  status      String    @default("scheduled") // scheduled, ongoing, completed, cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organizer   User      @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  organizerId String

  participants MeetingParticipant[]
  notes        MeetingNote[]

  @@map("meetings")
}

model MeetingParticipant {
  id        String    @id @default(uuid())
  meetingId String
  userId    String
  role      String    @default("participant") // organizer, participant
  status    String    @default("invited") // invited, accepted, declined, tentative
  joinedAt  DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model MeetingNote {
  id        String   @id @default(uuid())
  meetingId String
  content   Json // Yjs doc state for collaborative editing
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_notes")
}

// ============================================================
// 白板系統
// ============================================================

model Whiteboard {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String?
  title       String
  description String?
  thumbnail   String?
  data        Json? // Yjs document state
  isTemplate  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  sessions WhiteboardSession[]

  @@map("whiteboards")
}

model WhiteboardSession {
  id           String    @id @default(uuid())
  whiteboardId String
  userId       String
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@map("whiteboard_sessions")
}

// ============================================================
// 檔案管理
// ============================================================

model File {
  id           String    @id @default(uuid())
  workspaceId  String
  uploaderId   String
  messageId    String?
  taskId       String?
  fileName     String
  fileType     String
  fileSize     Int
  url          String
  thumbnailUrl String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  uploader User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("files")
}

// ============================================================
// 通知系統
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // message, mention, task_assigned, meeting_invite, etc.
  title     String
  content   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================================
// 文件與資料庫 (P5 Docs & Database)
//   D-02 結構化資料庫：支援自訂欄位 (text / number / date / select)
// ============================================================

model Database {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  icon        String?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("DatabaseCreator", fields: [createdBy], references: [id])

  columns DatabaseColumn[]
  rows    DatabaseRow[]

  @@index([workspaceId, deletedAt])
  @@map("databases")
}

model DatabaseColumn {
  id         String   @id @default(uuid())
  databaseId String
  name       String
  type       String // text, number, date, select
  options    Json? // select 型別選項：{ choices: [{id, label, color}] }
  position   Int      @default(0)
  required   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database       @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  cells    DatabaseCell[]

  @@unique([databaseId, name])
  @@map("database_columns")
}

model DatabaseRow {
  id         String    @id @default(uuid())
  databaseId String
  position   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  database Database       @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  cells    DatabaseCell[]

  @@index([databaseId, deletedAt, position])
  @@map("database_rows")
}

model DatabaseCell {
  id        String   @id @default(uuid())
  rowId     String
  columnId  String
  value     Json? // 依欄位型別：string / number / ISO date / select choice id
  updatedAt DateTime @updatedAt

  row    DatabaseRow    @relation(fields: [rowId], references: [id], onDelete: Cascade)
  column DatabaseColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([rowId, columnId])
  @@map("database_cells")
}

// ============================================================
// 到期與重複提醒 (D-07)
//   支援單次 / daily / weekly / monthly / yearly + interval
//   targetType/targetId 可指向 database_row 或 task；null = 純提醒
// ============================================================

// ============================================================
// 訊息範本 / 片段庫 (C-15)
//   visibility: personal (僅作者) | workspace (同工作空間成員皆可使用)
//   只有作者可以編輯 / 軟刪
// ============================================================

model MessageSnippet {
  id          String    @id @default(uuid())
  workspaceId String
  createdBy   String
  name        String
  content     String
  shortcut    String? // 例：/billing-notice
  visibility  String    @default("personal") // personal | workspace
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("SnippetCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([workspaceId, deletedAt, visibility])
  @@index([createdBy, deletedAt])
  @@map("message_snippets")
}

// ============================================================
// 自動化規則 (P-15)
//   事件觸發：task_completed (本刀暫時支援此單一 trigger)
//   scope: project — scopeId 指向 Project.id，執行時匹配 task.projectId
//   action: notify_user | post_to_channel
// ============================================================

model AutomationRule {
  id            String    @id @default(uuid())
  workspaceId   String
  createdBy     String
  name          String
  description   String?
  scope         String // project | database
  scopeId       String
  trigger       String // task_completed | task_moved_to_column | ...
  triggerConfig Json?
  action        String // notify_user | post_to_channel
  actionConfig  Json // 依 action 不同結構
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("AutomationRuleCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([scope, scopeId, trigger, enabled, deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("automation_rules")
}

// ============================================================
// 排程訊息 (C-17)
//   指定時間把訊息透過 C-16 broadcast 路徑送到 1+ 個頻道。
//   內容於 schedule 當下 snapshot；之後改 snippet 不影響排定內容。
// ============================================================

model ScheduledMessage {
  id              String    @id @default(uuid())
  workspaceId     String
  createdBy       String
  channelIds      String[]
  content         String?
  type            String    @default("text") // text | image | file | system
  metadata        Json?
  sendAt          DateTime
  status          String    @default("pending") // pending | sent | canceled | failed
  sentAt          DateTime?
  sentBroadcastId String?
  failedReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("ScheduledMessageCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([sendAt, status, deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("scheduled_messages")
}

model Reminder {
  id                 String    @id @default(uuid())
  workspaceId        String
  userId             String // 建立者
  title              String
  notes              String?
  targetType         String? // database_row | task
  targetId           String?
  triggerAt          DateTime // 第一次觸發時間
  recurrence         String    @default("none") // none | daily | weekly | monthly | yearly
  recurrenceInterval Int       @default(1)
  nextFireAt         DateTime // scheduler 輪詢用；與 triggerAt 同步 (第一次) 或 advance 後更新
  lastFiredAt        DateTime?
  status             String    @default("active") // active | paused | completed
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("ReminderCreator", fields: [userId], references: [id], onDelete: Cascade)

  @@index([nextFireAt, status, deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("reminders")
}
