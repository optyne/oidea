generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 使用者與認證
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  displayName   String
  passwordHash  String
  avatarUrl     String?
  status        String    @default("offline") // online, away, dnd, offline
  statusMessage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  accounts           Account[]
  workspaceMembers   WorkspaceMember[]
  channelMembers     ChannelMember[]
  sentMessages       Message[]            @relation("MessageSender")
  ownedWorkspaces    Workspace[]          @relation("WorkspaceOwner")
  assignedTasks      Task[]               @relation("TaskAssignee")
  taskComments       TaskComment[]
  meetingOrganizer   Meeting[]            @relation("MeetingOrganizer")
  meetingParticipant MeetingParticipant[]
  reactions          MessageReaction[]
  mentions           Mention[]
  readStatuses       MessageReadStatus[]
  typingIndicators   TypingIndicator[]
  notifications      Notification[]
  sharedFiles        File[]
  activities         TaskActivity[]
  expenses           Expense[]            @relation("ExpenseSubmitter")
  approvals          ExpenseApproval[]    @relation("ExpenseApprover")
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]       @relation("LeaveRequester")
  leaveApprovals     LeaveRequest[]       @relation("LeaveApprover")
  createdPages       KnowledgePage[]      @relation("PageCreatedBy")
  editedBlocks       KnowledgeBlock[]     @relation("BlockLastEditedBy")
  createdRows        DbRow[]              @relation("RowCreatedBy")
  pagePermissions    PagePermission[]
  auditEvents        AuditLog[]           @relation("AuditActor")

  @@map("users")
}

model Account {
  id           String   @id @default(uuid())
  userId       String
  provider     String // local, google, github
  providerId   String?
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("accounts")
}

// ============================================================
// 工作空間
// ============================================================

model Workspace {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  iconUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  ownerId String @map("ownerId")
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members        WorkspaceMember[]
  channels       Channel[]
  projects       Project[]
  meetings       Meeting[]
  boards         Whiteboard[]
  expenses       Expense[]
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  knowledgePages KnowledgePage[]
  auditLogs      AuditLog[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member") // owner, admin, hr, finance, member
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ============================================================
// 頻道與訊息
// ============================================================

model Channel {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  type        String    @default("public") // public, private, dm
  description String?
  topic       String?
  icon        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members        ChannelMember[]
  messages       Message[]
  pinnedMessages PinnedMessage[]

  @@unique([workspaceId, name])
  @@map("channels")
}

model ChannelMember {
  id         String   @id @default(uuid())
  channelId  String
  userId     String
  role       String   @default("member") // admin, member
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model Message {
  id        String    @id @default(uuid())
  channelId String
  senderId  String
  parentId  String? // for thread replies
  type      String    @default("text") // text, image, file, system
  content   String?
  metadata  Json? // extra data like file info
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  channel Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parent  Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Message[] @relation("MessageThread")

  reactions    MessageReaction[]
  readStatuses MessageReadStatus[]
  mentions     Mention[]
  pinnedIn     PinnedMessage[]
  files        File[]

  @@index([channelId, createdAt])
  @@index([parentId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageReadStatus {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_read_statuses")
}

model Mention {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mentions")
}

model PinnedMessage {
  id        String   @id @default(uuid())
  channelId String
  messageId String
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@map("pinned_messages")
}

model TypingIndicator {
  id        String   @id @default(uuid())
  channelId String
  userId    String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("typing_indicators")
}

// ============================================================
// 專案與任務
// ============================================================

model Project {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  icon        String?
  color       String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  columns ProjectColumn[]
  tasks   Task[]
  boards  Whiteboard[]

  @@map("projects")
}

model ProjectColumn {
  id        String  @id @default(uuid())
  projectId String
  name      String
  color     String?
  position  Int
  wipLimit  Int?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("project_columns")
}

model Task {
  id          String    @id @default(uuid())
  projectId   String
  columnId    String
  title       String
  description String?
  priority    String    @default("medium") // urgent, high, medium, low
  position    Int       @default(0)
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column     ProjectColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee   User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId String?

  tags       TaskTag[]
  comments   TaskComment[]
  subtasks   Subtask[]
  activities TaskActivity[]
  files      File[]

  @@index([projectId, columnId, position])
  @@map("tasks")
}

model TaskTag {
  id     String @id @default(uuid())
  taskId String
  name   String
  color  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_tags")
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Subtask {
  id        String  @id @default(uuid())
  taskId    String
  title     String
  completed Boolean @default(false)
  position  Int     @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("subtasks")
}

model TaskActivity {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String // created, moved, updated, assigned, commented
  details   Json?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_activities")
}

// ============================================================
// 會議系統
// ============================================================

model Meeting {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  meetingUrl  String?
  status      String    @default("scheduled") // scheduled, ongoing, completed, cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organizer   User      @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  organizerId String

  participants MeetingParticipant[]
  notes        MeetingNote[]

  @@map("meetings")
}

model MeetingParticipant {
  id        String    @id @default(uuid())
  meetingId String
  userId    String
  role      String    @default("participant") // organizer, participant
  status    String    @default("invited") // invited, accepted, declined, tentative
  joinedAt  DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model MeetingNote {
  id        String   @id @default(uuid())
  meetingId String
  content   Json // Yjs doc state for collaborative editing
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_notes")
}

// ============================================================
// 白板系統
// ============================================================

model Whiteboard {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String?
  title       String
  description String?
  thumbnail   String?
  data        Json? // Yjs document state
  isTemplate  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  sessions WhiteboardSession[]

  @@map("whiteboards")
}

model WhiteboardSession {
  id           String    @id @default(uuid())
  whiteboardId String
  userId       String
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@map("whiteboard_sessions")
}

// ============================================================
// 檔案管理
// ============================================================

model File {
  id           String    @id @default(uuid())
  workspaceId  String
  uploaderId   String
  messageId    String?
  taskId       String?
  fileName     String
  fileType     String
  fileSize     Int
  url          String
  thumbnailUrl String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  uploader User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("files")
}

// ============================================================
// 通知系統
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // message, mention, task_assigned, meeting_invite, expense_submitted, expense_approved, leave_approved, etc.
  title     String
  content   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================================
// ERP：費用報銷
// ============================================================

model Expense {
  id           String    @id @default(uuid())
  workspaceId  String
  submitterId  String
  title        String
  amount       Decimal   @db.Decimal(12, 2)
  currency     String    @default("TWD")
  category     String    @default("other") // travel, meal, transport, office, other
  description  String?
  incurredAt   DateTime  @default(now())
  status       String    @default("pending") // pending, approved, rejected, paid
  rejectReason String?
  paidAt       DateTime?
  paidBy       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submitter User              @relation("ExpenseSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  approvals ExpenseApproval[]
  receipts  ExpenseReceipt[]

  @@index([workspaceId, status, createdAt])
  @@index([submitterId, createdAt])
  @@map("expenses")
}

model ExpenseApproval {
  id         String   @id @default(uuid())
  expenseId  String
  approverId String
  decision   String // approved, rejected
  comment    String?
  decidedAt  DateTime @default(now())

  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approver User    @relation("ExpenseApprover", fields: [approverId], references: [id], onDelete: Cascade)

  @@index([expenseId, decidedAt])
  @@map("expense_approvals")
}

model ExpenseReceipt {
  id         String   @id @default(uuid())
  expenseId  String
  fileName   String
  fileType   String
  fileSize   Int
  url        String
  uploadedAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_receipts")
}

// ============================================================
// ERP：考勤打卡
// ============================================================

model Attendance {
  id               String    @id @default(uuid())
  workspaceId      String
  userId           String
  date             DateTime  @db.Date
  checkInAt        DateTime?
  checkOutAt       DateTime?
  workMinutes      Int       @default(0)
  checkInLocation  String?
  checkOutLocation String?
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, date])
  @@index([workspaceId, date])
  @@map("attendances")
}

model LeaveRequest {
  id           String    @id @default(uuid())
  workspaceId  String
  requesterId  String
  type         String // sick, annual, personal, unpaid, other
  startDate    DateTime  @db.Date
  endDate      DateTime  @db.Date
  reason       String?
  status       String    @default("pending") // pending, approved, rejected, cancelled
  approverId   String?
  decidedAt    DateTime?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requester User      @relation("LeaveRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User?     @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, startDate])
  @@index([requesterId, startDate])
  @@map("leave_requests")
}

// ============================================================
// 知識管理：Notion 風 Page + Block + Database
// ============================================================

/// 一個 Page 即為一份文件。可巢狀，亦可作為 [KnowledgeDatabase] 的容器。
model KnowledgePage {
  id          String    @id @default(uuid())
  workspaceId String
  parentId    String?
  createdById String
  title       String    @default("Untitled")
  icon        String? // emoji
  coverUrl    String?
  kind        String    @default("page") // page, database
  archived    Boolean   @default(false)
  position    Int       @default(0)
  /// 可見性：workspace=所有成員可 edit；private=僅 creator 與明確分享對象；restricted=無預設權限，需明確分享
  visibility       String  @default("workspace")
  /// 當本頁自己沒有 permissions 時，是否繼承父頁的權限設定
  inheritParentAcl Boolean @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      KnowledgePage?     @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    KnowledgePage[]    @relation("PageTree")
  createdBy   User               @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  blocks      KnowledgeBlock[]
  database    KnowledgeDatabase?
  permissions PagePermission[]

  @@index([workspaceId, parentId, position])
  @@map("knowledge_pages")
}

/// 單頁的明確分享權限：可指定 userId（特定人）或 role（工作空間角色），access=view/edit/full。
/// userId 與 role 必擇一（服務層強制）；同一頁不可對同一個 userId/role 各自重複設定。
model PagePermission {
  id        String   @id @default(uuid())
  pageId    String
  userId    String?
  role      String?  // admin / hr / finance / member
  access    String   // "view" | "edit" | "full"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@unique([pageId, role])
  @@index([userId])
  @@map("page_permissions")
}

/// Block 儲存於 Page 下。支援 text / h1 / h2 / h3 / todo / bullet / numbered / quote / code / divider / image 等類型。
model KnowledgeBlock {
  id             String   @id @default(uuid())
  pageId         String
  parentBlockId  String?
  type           String   @default("text")
  /// 統一以 JSON 儲存內容；例如 text: { text: "..." }、todo: { text, checked }、image: { url, caption }、code: { language, text }
  content        Json     @default("{}")
  position       Int      @default(0)
  lastEditedById String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  page         KnowledgePage    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parentBlock  KnowledgeBlock?  @relation("BlockTree", fields: [parentBlockId], references: [id], onDelete: Cascade)
  childBlocks  KnowledgeBlock[] @relation("BlockTree")
  lastEditedBy User?            @relation("BlockLastEditedBy", fields: [lastEditedById], references: [id], onDelete: SetNull)

  @@index([pageId, parentBlockId, position])
  @@map("knowledge_blocks")
}

/// 掛在某個 Page 之下的資料庫。一個 Page 最多一個 Database。
model KnowledgeDatabase {
  id          String   @id @default(uuid())
  pageId      String   @unique
  description String?
  /// 預設 view：table | list | board | calendar
  defaultView String   @default("table")
  /// 預留用於 finance 等範本識別
  template    String? // null = 一般, "finance_log" = 記帳
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page       KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  properties DbProperty[]
  rows       DbRow[]

  @@map("knowledge_databases")
}

model DbProperty {
  id         String   @id @default(uuid())
  databaseId String
  /// 對應 DbRow.values 的 key（建立後不應修改）
  key        String
  name       String
  /// text | number | select | multi_select | date | checkbox | url | person | currency
  type       String
  /// 型別相關設定，例如 select.options = [{ id, label, color }]、currency.code = "TWD"
  config     Json     @default("{}")
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database KnowledgeDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@unique([databaseId, key])
  @@map("db_properties")
}

model DbRow {
  id          String   @id @default(uuid())
  databaseId  String
  /// 以 property key → 值 的 JSON 物件保存
  values      Json     @default("{}")
  position    Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  database  KnowledgeDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  createdBy User              @relation("RowCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([databaseId, position])
  @@map("db_rows")
}

// ============================================================
// 審計日誌：記錄敏感操作（登入、權限變更、報銷審批、知識庫分享等）
// ============================================================

/// 不可變事件流。`actorId` 可為 null 代表系統事件或登入失敗（帳號不存在）。
/// action 使用 dot 命名：auth.login / auth.login_failed / knowledge.share / knowledge.visibility_change /
/// knowledge.delete / expense.approve / expense.reject / expense.mark_paid / workspace.role_change。
model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  workspaceId String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor     User?      @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
