generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 使用者與認證
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  displayName   String
  passwordHash  String
  avatarUrl     String?
  status        String    @default("offline") // online, away, dnd, offline
  statusMessage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  accounts           Account[]
  workspaceMembers   WorkspaceMember[]
  channelMembers     ChannelMember[]
  sentMessages       Message[]            @relation("MessageSender")
  ownedWorkspaces    Workspace[]          @relation("WorkspaceOwner")
  assignedTasks      Task[]               @relation("TaskAssignee")
  taskComments       TaskComment[]
  meetingOrganizer   Meeting[]            @relation("MeetingOrganizer")
  meetingParticipant MeetingParticipant[]
  reactions          MessageReaction[]
  mentions           Mention[]
  readStatuses       MessageReadStatus[]
  typingIndicators   TypingIndicator[]
  notifications      Notification[]
  sharedFiles        File[]
  activities         TaskActivity[]
  createdDatabases   Database[]           @relation("DatabaseCreator")
  reminders          Reminder[]           @relation("ReminderCreator")
  messageSnippets    MessageSnippet[]     @relation("SnippetCreator")
  scheduledMessages  ScheduledMessage[]   @relation("ScheduledMessageCreator")
  automationRules    AutomationRule[]     @relation("AutomationRuleCreator")
  expenses           Expense[]            @relation("ExpenseSubmitter")
  approvals          ExpenseApproval[]    @relation("ExpenseApprover")
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]       @relation("LeaveRequester")
  leaveApprovals     LeaveRequest[]       @relation("LeaveApprover")
  createdPages       KnowledgePage[]      @relation("PageCreatedBy")
  editedBlocks       KnowledgeBlock[]     @relation("BlockLastEditedBy")
  createdRows        DbRow[]              @relation("RowCreatedBy")
  pagePermissions    PagePermission[]
  auditEvents        AuditLog[]           @relation("AuditActor")
  createdInvites     WorkspaceInvite[]    @relation("InviteCreator")
  consumedInvites    WorkspaceInvite[]    @relation("InviteConsumer")
  botAccount         BotAccount?          @relation("BotAccountUser")
  createdBots        BotAccount[]         @relation("BotAccountCreator")

  @@map("users")
}

model Account {
  id           String   @id @default(uuid())
  userId       String
  provider     String // local, google, github
  providerId   String?
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("accounts")
}

// ============================================================
// 工作空間
// ============================================================

model Workspace {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  iconUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  ownerId String @map("ownerId")
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members           WorkspaceMember[]
  channels          Channel[]
  projects          Project[]
  meetings          Meeting[]
  boards            Whiteboard[]
  databases         Database[]
  reminders         Reminder[]
  snippets          MessageSnippet[]
  scheduledMessages ScheduledMessage[]
  automationRules   AutomationRule[]
  expenses          Expense[]
  attendances       Attendance[]
  leaveRequests     LeaveRequest[]
  knowledgePages    KnowledgePage[]
  auditLogs         AuditLog[]
  invites           WorkspaceInvite[]
  bots              BotAccount[]

  @@map("workspaces")
}

/// 工作空間邀請連結：管理員產 token，任何人憑連結可加入（未註冊者先註冊再接受）。
/// 一個 invite 只能被兌換一次（consumedAt 設值後作廢）。沒有 email 綁定—— 任何 logged-in user 拿到 token 都能接受（比 email 綁定好用、也避開 email 郵寄系統）。
model WorkspaceInvite {
  id               String    @id @default(uuid())
  workspaceId      String
  /// 隨機 32+ bytes base64url 字串；URL-safe
  token            String    @unique
  /// 被邀請者登記的 email（可選，僅作紀錄；不強制 invitee 用此 email）
  email            String?
  /// 核准後授予的角色
  role             String    @default("member")
  createdById      String
  /// 過期時間（預設 7 天後）
  expiresAt        DateTime
  /// 被接受時間；non-null 代表作廢
  consumedAt       DateTime?
  consumedByUserId String?
  createdAt        DateTime  @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy     User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  consumedBy    User?     @relation("InviteConsumer", fields: [consumedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, consumedAt])
  @@index([token])
  @@map("workspace_invites")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member") // owner, admin, hr, finance, member
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ============================================================
// 頻道與訊息
// ============================================================

model Channel {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  type        String    @default("public") // public, private, dm
  description String?
  topic       String?
  icon        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members        ChannelMember[]
  messages       Message[]
  pinnedMessages PinnedMessage[]

  @@unique([workspaceId, name])
  @@map("channels")
}

model ChannelMember {
  id         String   @id @default(uuid())
  channelId  String
  userId     String
  role       String   @default("member") // admin, member
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model Message {
  id          String    @id @default(uuid())
  channelId   String
  senderId    String
  parentId    String? // for thread replies
  broadcastId String? // C-16 跨頻道廣播：同一批廣播出去的訊息共用此 id
  type        String    @default("text") // text, image, file, system
  content     String?
  metadata    Json? // extra data like file info
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  channel Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parent  Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Message[] @relation("MessageThread")

  reactions       MessageReaction[]
  readStatuses    MessageReadStatus[]
  mentions        Mention[]
  pinnedIn        PinnedMessage[]
  files           File[]
  convertedTasks  Task[]              @relation("MessageConvertedTasks")

  @@index([channelId, createdAt])
  @@index([parentId])
  @@index([broadcastId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageReadStatus {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_read_statuses")
}

model Mention {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mentions")
}

model PinnedMessage {
  id        String   @id @default(uuid())
  channelId String
  messageId String
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@map("pinned_messages")
}

model TypingIndicator {
  id        String   @id @default(uuid())
  channelId String
  userId    String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("typing_indicators")
}

// ============================================================
// 專案與任務
// ============================================================

model Project {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  icon        String?
  color       String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  columns ProjectColumn[]
  tasks   Task[]
  boards  Whiteboard[]

  @@map("projects")
}

model ProjectColumn {
  id        String  @id @default(uuid())
  projectId String
  name      String
  color     String?
  position  Int
  wipLimit  Int?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("project_columns")
}

model Task {
  id                 String    @id @default(uuid())
  projectId          String
  columnId           String
  title              String
  description        String?
  priority           String    @default("medium") // urgent, high, medium, low
  position           Int       @default(0)
  dueDate            DateTime?
  startDate          DateTime?
  completedAt        DateTime?
  sourceMessageId    String? // C-18 訊息轉任務：可回溯訊息來源
  recurrence         String    @default("none") // P-14: none | daily | weekly | monthly | yearly
  recurrenceInterval Int       @default(1)
  recurringSourceId  String? // P-14: 指向本循環序列的根任務
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column          ProjectColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee        User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId      String?
  sourceMessage   Message?      @relation("MessageConvertedTasks", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  recurringSource Task?         @relation("TaskRecurringSeries", fields: [recurringSourceId], references: [id], onDelete: SetNull)
  recurringInstances Task[]     @relation("TaskRecurringSeries")

  tags       TaskTag[]
  comments   TaskComment[]
  subtasks   Subtask[]
  activities TaskActivity[]
  files      File[]

  @@index([projectId, columnId, position])
  @@index([sourceMessageId])
  @@index([recurringSourceId])
  @@map("tasks")
}

model TaskTag {
  id     String @id @default(uuid())
  taskId String
  name   String
  color  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_tags")
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Subtask {
  id        String  @id @default(uuid())
  taskId    String
  title     String
  completed Boolean @default(false)
  position  Int     @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("subtasks")
}

model TaskActivity {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String // created, moved, updated, assigned, commented
  details   Json?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_activities")
}

// ============================================================
// 會議系統
// ============================================================

model Meeting {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  meetingUrl  String?
  status      String    @default("scheduled") // scheduled, ongoing, completed, cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organizer   User      @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  organizerId String

  participants MeetingParticipant[]
  notes        MeetingNote[]

  @@map("meetings")
}

model MeetingParticipant {
  id        String    @id @default(uuid())
  meetingId String
  userId    String
  role      String    @default("participant") // organizer, participant
  status    String    @default("invited") // invited, accepted, declined, tentative
  joinedAt  DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model MeetingNote {
  id        String   @id @default(uuid())
  meetingId String
  content   Json // Yjs doc state for collaborative editing
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_notes")
}

// ============================================================
// 白板系統
// ============================================================

model Whiteboard {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String?
  title       String
  description String?
  thumbnail   String?
  data        Json? // Yjs document state
  isTemplate  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  sessions WhiteboardSession[]

  @@map("whiteboards")
}

model WhiteboardSession {
  id           String    @id @default(uuid())
  whiteboardId String
  userId       String
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@map("whiteboard_sessions")
}

// ============================================================
// 檔案管理
// ============================================================

model File {
  id           String    @id @default(uuid())
  workspaceId  String
  uploaderId   String
  messageId    String?
  taskId       String?
  fileName     String
  fileType     String
  fileSize     Int
  url          String
  thumbnailUrl String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  uploader User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("files")
}

// ============================================================
// 通知系統
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // message, mention, task_assigned, meeting_invite, expense_submitted, expense_approved, leave_approved, etc.
  title     String
  content   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================================
// ============================================================
// 文件與資料庫 (P5 Docs & Database)
//   D-02 結構化資料庫：支援自訂欄位 (text / number / date / select)
// ============================================================

model Database {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  icon        String?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("DatabaseCreator", fields: [createdBy], references: [id])

  columns DatabaseColumn[]
  rows    DatabaseRow[]

  @@index([workspaceId, deletedAt])
  @@map("databases")
}

model DatabaseColumn {
  id         String   @id @default(uuid())
  databaseId String
  name       String
  type       String // text, number, date, select
  options    Json? // select 型別選項：{ choices: [{id, label, color}] }
  position   Int      @default(0)
  required   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database       @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  cells    DatabaseCell[]

  @@unique([databaseId, name])
  @@map("database_columns")
}

model DatabaseRow {
  id         String    @id @default(uuid())
  databaseId String
  position   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  database Database       @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  cells    DatabaseCell[]

  @@index([databaseId, deletedAt, position])
  @@map("database_rows")
}

model DatabaseCell {
  id        String   @id @default(uuid())
  rowId     String
  columnId  String
  value     Json? // 依欄位型別：string / number / ISO date / select choice id
  updatedAt DateTime @updatedAt

  row    DatabaseRow    @relation(fields: [rowId], references: [id], onDelete: Cascade)
  column DatabaseColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([rowId, columnId])
  @@map("database_cells")
}

// ============================================================
// 訊息範本 / 片段庫 (C-15)
// ============================================================

model MessageSnippet {
  id          String    @id @default(uuid())
  workspaceId String
  createdBy   String
  name        String
  content     String
  shortcut    String? // 例：/billing-notice
  visibility  String    @default("personal") // personal | workspace
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("SnippetCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([workspaceId, deletedAt, visibility])
  @@index([createdBy, deletedAt])
  @@map("message_snippets")
}

// ============================================================
// 自動化規則 (P-15)
// ============================================================

model AutomationRule {
  id            String    @id @default(uuid())
  workspaceId   String
  createdBy     String
  name          String
  description   String?
  scope         String // project | database
  scopeId       String
  trigger       String // task_completed | task_moved_to_column | ...
  triggerConfig Json?
  action        String // notify_user | post_to_channel
  actionConfig  Json // 依 action 不同結構
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("AutomationRuleCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([scope, scopeId, trigger, enabled, deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("automation_rules")
}

// ============================================================
// 排程訊息 (C-17)
// ============================================================

model ScheduledMessage {
  id              String    @id @default(uuid())
  workspaceId     String
  createdBy       String
  channelIds      String[]
  content         String?
  type            String    @default("text") // text | image | file | system
  metadata        Json?
  sendAt          DateTime
  status          String    @default("pending") // pending | sent | canceled | failed
  sentAt          DateTime?
  sentBroadcastId String?
  failedReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("ScheduledMessageCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([sendAt, status, deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("scheduled_messages")
}

// ============================================================
// 到期與重複提醒 (D-07)
// ============================================================

model Reminder {
  id                 String    @id @default(uuid())
  workspaceId        String
  userId             String // 建立者
  title              String
  notes              String?
  targetType         String? // database_row | task
  targetId           String?
  triggerAt          DateTime // 第一次觸發時間
  recurrence         String    @default("none") // none | daily | weekly | monthly | yearly
  recurrenceInterval Int       @default(1)
  nextFireAt         DateTime // scheduler 輪詢用
  lastFiredAt        DateTime?
  status             String    @default("active") // active | paused | completed
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("ReminderCreator", fields: [userId], references: [id], onDelete: Cascade)

  @@index([nextFireAt, status, deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("reminders")
}

// ============================================================
// ERP：費用報銷
// ============================================================

model Expense {
  id           String    @id @default(uuid())
  workspaceId  String
  submitterId  String
  title        String
  amount       Decimal   @db.Decimal(12, 2)
  currency     String    @default("TWD")
  category     String    @default("other") // travel, meal, transport, office, other
  description  String?
  incurredAt   DateTime  @default(now())
  status       String    @default("pending") // pending, approved, rejected, paid
  rejectReason String?
  paidAt       DateTime?
  paidBy       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submitter User              @relation("ExpenseSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  approvals ExpenseApproval[]
  receipts  ExpenseReceipt[]

  @@index([workspaceId, status, createdAt])
  @@index([submitterId, createdAt])
  @@map("expenses")
}

model ExpenseApproval {
  id         String   @id @default(uuid())
  expenseId  String
  approverId String
  decision   String // approved, rejected
  comment    String?
  decidedAt  DateTime @default(now())

  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approver User    @relation("ExpenseApprover", fields: [approverId], references: [id], onDelete: Cascade)

  @@index([expenseId, decidedAt])
  @@map("expense_approvals")
}

model ExpenseReceipt {
  id         String   @id @default(uuid())
  expenseId  String
  fileName   String
  fileType   String
  fileSize   Int
  url        String
  uploadedAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_receipts")
}

// ============================================================
// ERP：考勤打卡
// ============================================================

model Attendance {
  id               String    @id @default(uuid())
  workspaceId      String
  userId           String
  date             DateTime  @db.Date
  checkInAt        DateTime?
  checkOutAt       DateTime?
  workMinutes      Int       @default(0)
  checkInLocation  String?
  checkOutLocation String?
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, date])
  @@index([workspaceId, date])
  @@map("attendances")
}

model LeaveRequest {
  id           String    @id @default(uuid())
  workspaceId  String
  requesterId  String
  type         String // sick, annual, personal, unpaid, other
  startDate    DateTime  @db.Date
  endDate      DateTime  @db.Date
  reason       String?
  status       String    @default("pending") // pending, approved, rejected, cancelled
  approverId   String?
  decidedAt    DateTime?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requester User      @relation("LeaveRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User?     @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, startDate])
  @@index([requesterId, startDate])
  @@map("leave_requests")
}

// ============================================================
// 知識管理：Notion 風 Page + Block + Database
// ============================================================

/// 一個 Page 即為一份文件。可巢狀，亦可作為 [KnowledgeDatabase] 的容器。
model KnowledgePage {
  id          String    @id @default(uuid())
  workspaceId String
  parentId    String?
  createdById String
  title       String    @default("Untitled")
  icon        String? // emoji
  coverUrl    String?
  kind        String    @default("page") // page, database
  archived    Boolean   @default(false)
  position    Int       @default(0)
  /// 可見性：workspace=所有成員可 edit；private=僅 creator 與明確分享對象；restricted=無預設權限，需明確分享
  visibility       String  @default("workspace")
  /// 當本頁自己沒有 permissions 時，是否繼承父頁的權限設定
  inheritParentAcl Boolean @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      KnowledgePage?     @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    KnowledgePage[]    @relation("PageTree")
  createdBy   User               @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  blocks      KnowledgeBlock[]
  database    KnowledgeDatabase?
  permissions PagePermission[]

  @@index([workspaceId, parentId, position])
  @@map("knowledge_pages")
}

/// 單頁的明確分享權限：可指定 userId（特定人）或 role（工作空間角色），access=view/edit/full。
model PagePermission {
  id        String   @id @default(uuid())
  pageId    String
  userId    String?
  role      String?  // admin / hr / finance / member
  access    String   // "view" | "edit" | "full"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@unique([pageId, role])
  @@index([userId])
  @@map("page_permissions")
}

/// Block 儲存於 Page 下。支援 text / h1 / h2 / h3 / todo / bullet / numbered / quote / code / divider / image 等類型。
model KnowledgeBlock {
  id             String   @id @default(uuid())
  pageId         String
  parentBlockId  String?
  type           String   @default("text")
  content        Json     @default("{}")
  position       Int      @default(0)
  lastEditedById String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  page         KnowledgePage    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parentBlock  KnowledgeBlock?  @relation("BlockTree", fields: [parentBlockId], references: [id], onDelete: Cascade)
  childBlocks  KnowledgeBlock[] @relation("BlockTree")
  lastEditedBy User?            @relation("BlockLastEditedBy", fields: [lastEditedById], references: [id], onDelete: SetNull)

  @@index([pageId, parentBlockId, position])
  @@map("knowledge_blocks")
}

/// 掛在某個 Page 之下的資料庫。一個 Page 最多一個 Database。
model KnowledgeDatabase {
  id          String   @id @default(uuid())
  pageId      String   @unique
  description String?
  defaultView String   @default("table")
  template    String? // null = 一般, "finance_log" = 記帳
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page       KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  properties DbProperty[]
  rows       DbRow[]

  @@map("knowledge_databases")
}

model DbProperty {
  id         String   @id @default(uuid())
  databaseId String
  key        String
  name       String
  type       String
  config     Json     @default("{}")
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database KnowledgeDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@unique([databaseId, key])
  @@map("db_properties")
}

model DbRow {
  id          String   @id @default(uuid())
  databaseId  String
  values      Json     @default("{}")
  position    Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  database  KnowledgeDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  createdBy User              @relation("RowCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([databaseId, position])
  @@map("db_rows")
}

// ============================================================
// 審計日誌：記錄敏感操作（登入、權限變更、報銷審批、知識庫分享等）
// ============================================================

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  workspaceId String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor     User?      @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ============================================================
// Bot 整合：外部程式（Claude Code / 自訂 agent）透過 token 存取 Oidea
// ============================================================

/// 每個 bot 有一條對應的 User（senderId 可直接指過去，現有 message FK 不變）
/// 加一個 BotAccount 保存 token hash、擁有者、狀態等 metadata。
model BotAccount {
  id           String    @id @default(uuid())
  workspaceId  String
  /// 對應的 bot User row（與 `User.botAccount` 1:1）
  userId       String    @unique
  name         String
  description  String?
  /// bcrypt hash of the full token; plaintext 只在 create response 回一次
  tokenHash    String
  /// Token 前 10 字元（含 `bot_` 前綴），用來在收到請求時快速查哪個 bot
  tokenPrefix  String    @unique
  /// 建立者（授權稽核用）
  createdById  String
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("BotAccountUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User      @relation("BotAccountCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, revokedAt])
  @@map("bot_accounts")
}
