DATABASE_URL="postgresql://oidea:oidea_secret_dev@localhost:5433/oidea?schema=public"
REDIS_HOST="localhost"
REDIS_PORT=6379
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="oidea_minio"
MINIO_SECRET_KEY="oidea_minio_secret_dev"
MINIO_BUCKET="oidea-uploads"
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
PORT=3001

# ── Redis 連線（管理型 Redis 通常會開 AUTH）────────────────────────────
REDIS_PASSWORD=""
REDIS_USERNAME=""

# ── Oidea AI 助手（@ai 在 chat 觸發 Claude）──────────────────────────
# 若不要 AI 功能：AI_ENABLED=false，或乾脆不設 ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=""
AI_ENABLED="true"
AI_MODEL="claude-opus-4-7"
AI_EFFORT="high"               # low | medium | high | xhigh | max
AI_RATE_LIMIT_PER_HOUR="10"    # 每個使用者每小時最多 @ai 次數
